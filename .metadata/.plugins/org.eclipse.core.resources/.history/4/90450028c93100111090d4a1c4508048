        public void closePasskeyPopupIfPresent() {
            try {
                JavascriptExecutor js = (JavascriptExecutor) driver;

                // Query inside the shadow DOM
                WebElement closeBtn = (WebElement) js.executeScript(
                    "return document.querySelector('amazon-passkey-dialog')" +
                    ".shadowRoot.querySelector('button')"
                );

                if (closeBtn != null) {
                    js.executeScript("arguments[0].click();", closeBtn);
                    System.out.println("Passkey popup closed.");
                } else {
                    System.out.println("Close button not found inside shadow DOM.");
                }
            } catch (Exception e) {
                System.out.println("No passkey popup appeared or could not be closed: " + e.getMessage());
            }
        }
